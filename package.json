  "license": "ISC",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "servor": "^4.0.2",
    "daisyui": "^5.5.19"
  }
}
