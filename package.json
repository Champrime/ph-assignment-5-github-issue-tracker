{
  "name": "ph-assignment-5-github-issue-tracker",
  "version": "1.0.0",
  "description": "",
  "main": "index.html",
  "scripts": {
    "start": "servor --browse --reload",
    "dev": "tailwindcss -i ./src/twInput.css -o ./src/twOutput.css --watch 2>&1 | while IFS= read -r line; do echo \"[$(date '+%I:%M:%S %p')] $line\"; done",
    "build": "tailwindcss -i ./src/twInput.css -o ./src/twOutput.css --minify",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "\"Daisy",
    "UI\"",
    "\"Tailwind",
    "CSS\"",
    "\"Vanilla",
    "JavaScript\""
  ],
